package rules.cep;

import com.truckdispatch.truck_dispatch.model.FleetEvent;
import com.truckdispatch.truck_dispatch.model.FleetEventType;
import com.truckdispatch.truck_dispatch.model.DeliveryOrder;
import com.truckdispatch.truck_dispatch.model.Truck;
import com.truckdispatch.truck_dispatch.model.Alarm;
import com.truckdispatch.truck_dispatch.model.AlarmType;
import com.truckdispatch.truck_dispatch.model.OrderStatus;
import com.truckdispatch.truck_dispatch.model.TruckStatus;

// Temporalni patterni nad event streamom (Drools Fusion / CEP).
// Lifecycle tranzicije naloga su u lifecycle.drl (isti kbase, ista sesija).

global java.util.List messages;

// Deklarisanje FleetEvent kao CEP dogadjaj (umjesto Java anotacija)
declare FleetEvent
    @role(event)
    @timestamp(timestamp)
    @expires(1h)
end

// CEP PRAVILA - Drools Fusion (stream mode)
// Svi FleetEvent objekti su @Role(event) - imaju timestamp

// 1. Tri kasnjenja istog kamiona u roku od 30 minuta -> eskalacija
rule "CEP_DelayEscalation"
    when
        $e1 : FleetEvent(type == FleetEventType.DELAY, $truckId : entityId)
        $e2 : FleetEvent(type == FleetEventType.DELAY, entityId == $truckId,
                         this != $e1, this after[1ms, 30m] $e1)
        $e3 : FleetEvent(type == FleetEventType.DELAY, entityId == $truckId,
                         this != $e1, this != $e2, this after[1ms, 30m] $e1)
    then
        insert(new Alarm(AlarmType.ESCALATION, $truckId,
                "3 delays in 30 min - priority redistribution!", 3));
        messages.add("CEP ALERT: 3 delays for truck " + $truckId + " in 30min - redistribute priorities!");
end

// 2. Kamion na istoj GPS lokaciji > 20 minuta tokom aktivne dostave -> stoji
rule "CEP_VehicleStopped"
    when
        $e1 : FleetEvent(type == FleetEventType.POSITION, $truckId : entityId, $loc : location)
        $e2 : FleetEvent(type == FleetEventType.POSITION, entityId == $truckId,
                         location == $loc, this != $e1, this after[20m, *] $e1)
        not  FleetEvent(type == FleetEventType.POSITION, entityId == $truckId,
                         location != $loc, this after $e1, this before $e2)
        exists DeliveryOrder(status == OrderStatus.IN_PROGRESS, assignedTruckId == $truckId)
        not   DeliveryOrder(status == OrderStatus.WAITING_UNLOADING, assignedTruckId == $truckId)
    then
        insert(new Alarm(AlarmType.VEHICLE_STOPPED, $truckId,
                "Truck " + $truckId + " stopped >20min at " + $loc, 0));
        messages.add("CEP ALERT: truck " + $truckId + " stopped >20min at location " + $loc);
end

// 3. Kvar tokom aktivnog naloga -> hitna zamena
rule "CEP_BreakdownDuringOrder"
    when
        $event  : FleetEvent(type == FleetEventType.BREAKDOWN, $truckId : entityId)
        $order  : DeliveryOrder(status == OrderStatus.IN_PROGRESS, assignedTruckId == $truckId,
                                $weight : weightKg)
        $spare  : Truck(status == TruckStatus.AVAILABLE, maxCapacityKg >= $weight,
                        id != $truckId)
    then
        modify($spare) { setStatus(TruckStatus.BUSY); }
        modify($order) {
            setStatus(OrderStatus.REPLANNED),
            setAssignedTruckId($spare.getId())
        }
        insert(new Alarm(AlarmType.EMERGENCY_REPLACEMENT, $truckId,
                "Breakdown - order " + $order.getId() + " transferred to " + $spare.getId(), 0));
        messages.add("CEP ALERT: breakdown " + $truckId + " - order " + $order.getId()
                + " replanned to " + $spare.getId() + " — dispatch spare to breakdown location for cargo transfer!");
end

// 7. Spike naloga - 5+ novih naloga u 15 minuta
rule "CEP_OrderSpike"
    when
        $count : Number(intValue >= 5) from accumulate(
            $e : FleetEvent(type == FleetEventType.NEW_ORDER) over window:time(15m),
            count($e)
        )
    then
        insert(new Alarm(AlarmType.ORDER_SPIKE, "FLEET",
                "Order spike: " + $count + " new orders in 15min!", $count.intValue()));
        messages.add("CEP ALERT: spike - " + $count + " new orders in 15min - activating prioritization mode!");
end

// 8. Nagli pad goriva > 15% za 10 minuta -> sumnja na kvar
rule "CEP_FuelDrop"
    when
        $e1 : FleetEvent(type == FleetEventType.FUEL_LEVEL, $truckId : entityId, $g1 : value)
        $e2 : FleetEvent(type == FleetEventType.FUEL_LEVEL, entityId == $truckId,
                         this != $e1, this after[0ms, 10m] $e1, value < $g1 - 15)
    then
        insert(new Alarm(AlarmType.FUEL_LEAK, $truckId,
                "Fuel drop " + ($g1 - $e2.getValue()) + "% in 10min - possible leak!", 0));
        messages.add("CEP ALERT: truck " + $truckId + " fuel dropped " + ($g1 - $e2.getValue())
                + "% in 10min - possible malfunction!");
end

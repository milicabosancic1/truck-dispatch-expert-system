package rules;

import com.truckdispatch.truck_dispatch.model.DeliveryOrder;
import com.truckdispatch.truck_dispatch.model.Truck;
import com.truckdispatch.truck_dispatch.model.Driver;
import com.truckdispatch.truck_dispatch.model.CandidateTruck;
import com.truckdispatch.truck_dispatch.model.ValidPair;
import com.truckdispatch.truck_dispatch.model.OrderStatus;
import com.truckdispatch.truck_dispatch.model.CargoType;
import com.truckdispatch.truck_dispatch.model.TruckStatus;
import com.truckdispatch.truck_dispatch.model.DispatchContext;
import com.truckdispatch.truck_dispatch.model.OperationalContext;

global java.util.List messages;

// NIVO 3: Provera vozaca i kreiranje ValidPair

// Standardni teret, nije NIGHT_MODE -- fatigue < 7
rule "CreateValidPair"
    salience 700
    when
        not DispatchContext(context == OperationalContext.NIGHT_MODE)
        $candidate : CandidateTruck($order : order, order.cargoType != CargoType.HAZARDOUS, $truck : truck)
        $driver : Driver(
            available == true,
            workingHoursToday < 8.0,
            fatigueLevel < 7,
            isLicensedFor($truck.type) == true
        )
        not ValidPair(order == $order, truck == $truck, driver == $driver)
    then
        insert(new ValidPair($order, $truck, $driver, 100));
end

// Standardni teret, NIGHT_MODE: fatigue <= 5
rule "CreateValidPair_NightMode"
    salience 700
    when
        DispatchContext(context == OperationalContext.NIGHT_MODE)
        $candidate : CandidateTruck($order : order, order.cargoType != CargoType.HAZARDOUS, $truck : truck)
        $driver : Driver(
            available == true,
            workingHoursToday < 8.0,
            fatigueLevel <= 5,
            isLicensedFor($truck.type) == true
        )
        not ValidPair(order == $order, truck == $truck, driver == $driver)
    then
        insert(new ValidPair($order, $truck, $driver, 100));
end

// Opasna roba, nije NIGHT_MODE -- vozac mora imati ADR licencu, fatigue < 7
rule "CreateValidPair_ADR"
    salience 700
    when
        not DispatchContext(context == OperationalContext.NIGHT_MODE)
        $candidate : CandidateTruck($order : order, order.cargoType == CargoType.HAZARDOUS, $truck : truck)
        $driver : Driver(
            available == true,
            workingHoursToday < 8.0,
            fatigueLevel < 7,
            isLicensedFor($truck.type) == true,
            hasAdrLicense == true
        )
        not ValidPair(order == $order, truck == $truck, driver == $driver)
    then
        insert(new ValidPair($order, $truck, $driver, 100));
end

// Opasna roba, NIGHT_MODE -- ADR licenca + stroze: fatigue <= 5
rule "CreateValidPair_ADR_NightMode"
    salience 700
    when
        DispatchContext(context == OperationalContext.NIGHT_MODE)
        $candidate : CandidateTruck($order : order, order.cargoType == CargoType.HAZARDOUS, $truck : truck)
        $driver : Driver(
            available == true,
            workingHoursToday < 8.0,
            fatigueLevel <= 5,
            isLicensedFor($truck.type) == true,
            hasAdrLicense == true
        )
        not ValidPair(order == $order, truck == $truck, driver == $driver)
    then
        insert(new ValidPair($order, $truck, $driver, 100));
end

// Poruka kad vozac pokusa biti par sa ADR nalogom bez licence
rule "ExcludeDriver_NoADR"
    salience 710
    when
        $candidate : CandidateTruck($order : order, order.cargoType == CargoType.HAZARDOUS)
        $driver : Driver(hasAdrLicense == false)
    then
        messages.add("Driver " + $driver.getId() + " excluded -- no ADR license for order " + $order.getId());
end

// Nema dostupnog para -- ili nikad nije kreiran, ili su svi resursi zauzeti
rule "NoValidPairFound"
    salience 10
    when
        $order : DeliveryOrder(status == OrderStatus.VALID)
        not (ValidPair(order == $order, $bt : truck, $bd : driver)
             and Truck(this == $bt,  status == TruckStatus.AVAILABLE)
             and Driver(this == $bd, available == true))
    then
        modify($order) { setStatus(OrderStatus.WAITING_RESOURCES); }
        messages.add("Order " + $order.getId() + " waiting for resources -- no available truck+driver combination. Run BC diagnostics.");
end

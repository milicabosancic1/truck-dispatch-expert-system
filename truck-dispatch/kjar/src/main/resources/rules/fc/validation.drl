package rules;

import com.truckdispatch.truck_dispatch.model.DeliveryOrder;
import com.truckdispatch.truck_dispatch.model.Truck;
import com.truckdispatch.truck_dispatch.model.Route;
import com.truckdispatch.truck_dispatch.model.DispatchContext;
import com.truckdispatch.truck_dispatch.model.OrderStatus;
import com.truckdispatch.truck_dispatch.model.OrderPriority;
import com.truckdispatch.truck_dispatch.model.TruckStatus;
import com.truckdispatch.truck_dispatch.model.OperationalContext;
import com.truckdispatch.truck_dispatch.model.CargoType;
import com.truckdispatch.truck_dispatch.model.RoadType;

global java.util.List messages;

// NIVO 1: Validacija naloga

rule "Validation_Feasible_Normal"
    salience 900
    when
        $order : DeliveryOrder(status == OrderStatus.NEW)
        not DispatchContext(context == OperationalContext.WINTER_CONDITIONS)
        exists Truck(status == TruckStatus.AVAILABLE, maxCapacityKg >= $order.weightKg)
    then
        modify($order) { setStatus(OrderStatus.VALID); }
        messages.add("Order " + $order.getId() + " is VALID (weight=" + $order.getWeightKg() + "kg)");
end

rule "Validation_Feasible_Winter"
    salience 900
    when
        $order : DeliveryOrder(status == OrderStatus.NEW)
        $ctx : DispatchContext(context == OperationalContext.WINTER_CONDITIONS, $factor : capacityFactor)
        exists Truck(status == TruckStatus.AVAILABLE, maxCapacityKg * $factor >= $order.weightKg)
    then
        modify($order) { setStatus(OrderStatus.VALID); }
        messages.add("Order " + $order.getId() + " is VALID (winter factor=" + $factor + ")");
end

rule "Validation_Infeasible_Normal"
    salience 900
    when
        $order : DeliveryOrder(status == OrderStatus.NEW)
        not DispatchContext(context == OperationalContext.WINTER_CONDITIONS)
        not Truck(maxCapacityKg >= $order.weightKg)
    then
        modify($order) { setStatus(OrderStatus.UNFEASIBLE); }
        messages.add("Order " + $order.getId() + " is UNFEASIBLE — no truck in fleet with enough capacity. Consider subcontractor.");
end

rule "Validation_BusyTrucks_Normal"
    salience 900
    when
        $order : DeliveryOrder(status == OrderStatus.NEW)
        not DispatchContext(context == OperationalContext.WINTER_CONDITIONS)
        exists Truck(maxCapacityKg >= $order.weightKg)
        not Truck(status == TruckStatus.AVAILABLE, maxCapacityKg >= $order.weightKg)
    then
        modify($order) { setStatus(OrderStatus.WAITING_RESOURCES); }
        messages.add("Order " + $order.getId() + " waiting — all trucks with sufficient capacity are currently busy.");
end

rule "Validation_Infeasible_Winter"
    salience 900
    when
        $order : DeliveryOrder(status == OrderStatus.NEW)
        $ctx : DispatchContext(context == OperationalContext.WINTER_CONDITIONS, $factor : capacityFactor)
        not Truck(maxCapacityKg * $factor >= $order.weightKg)
    then
        modify($order) { setStatus(OrderStatus.UNFEASIBLE); }
        messages.add("Order " + $order.getId() + " is UNFEASIBLE — winter conditions reduce effective capacity below " + $order.getWeightKg() + "kg");
end

rule "Validation_BusyTrucks_Winter"
    salience 900
    when
        $order : DeliveryOrder(status == OrderStatus.NEW)
        $ctx : DispatchContext(context == OperationalContext.WINTER_CONDITIONS, $factor : capacityFactor)
        exists Truck(maxCapacityKg * $factor >= $order.weightKg)
        not Truck(status == TruckStatus.AVAILABLE, maxCapacityKg * $factor >= $order.weightKg)
    then
        modify($order) { setStatus(OrderStatus.WAITING_RESOURCES); }
        messages.add("Order " + $order.getId() + " waiting — all trucks with sufficient capacity are currently busy (winter conditions).");
end

rule "Validation_UrgentOrder"
    salience 880
    when
        $order : DeliveryOrder(status == OrderStatus.VALID, deliveryDeadlineMin < 120)
    then
        modify($order) { setPriority(OrderPriority.URGENT); }
        messages.add("Order " + $order.getId() + " marked URGENT (deadline=" + $order.getDeliveryDeadlineMin() + "min)");
end

// NIVO 1: Validacija tipa tereta

rule "CargoType_Refrigerated_NoFrigoTruck"
    salience 870
    when
        $order : DeliveryOrder(status == OrderStatus.VALID, cargoType == CargoType.REFRIGERATED)
        not (exists Truck(hasRefrigerationUnit == true))
    then
        modify($order) { setStatus(OrderStatus.UNFEASIBLE); }
        messages.add("Order " + $order.getId() + " UNFEASIBLE — no refrigerated truck in fleet!");
end

rule "CargoType_ADR_TunnelRoute"
    salience 870
    when
        $order : DeliveryOrder(status == OrderStatus.VALID, cargoType == CargoType.HAZARDOUS)
        $route : Route(id == $order.routeId, hasTunnel == true)
    then
        messages.add("ADR order " + $order.getId() + " WARNING: route " + $route.getId() + " has tunnel — dispatcher must select alternative route!");
end

rule "CargoType_NightMode_OnlyUrgent"
    salience 870
    when
        $order : DeliveryOrder(status == OrderStatus.VALID, priority != OrderPriority.URGENT, priority != OrderPriority.CRITICAL_DELIVERY)
        DispatchContext(context == OperationalContext.NIGHT_MODE)
        not DispatchContext(context == OperationalContext.WEEKEND)
    then
        modify($order) { setStatus(OrderStatus.WAITING_RESOURCES); }
        messages.add("Night mode: order " + $order.getId() + " postponed — only URGENT orders allowed at night");
end

rule "CargoType_Weekend_OnlyUrgentAndHigh"
    salience 870
    when
        $order : DeliveryOrder(status == OrderStatus.VALID, priority == OrderPriority.NORMAL)
        DispatchContext(context == OperationalContext.WEEKEND)
    then
        modify($order) { setStatus(OrderStatus.WAITING_RESOURCES); }
        messages.add("Weekend mode: order " + $order.getId() + " postponed — only URGENT and HIGH orders dispatched on weekends");
end

// Opasan teret zabranjen u gradskim zonama (zakonska regulativa ADR u urbanim sredinama)
rule "Validation_Hazardous_CityRoute"
    salience 869
    when
        $order : DeliveryOrder(status == OrderStatus.VALID, cargoType == CargoType.HAZARDOUS)
        $route : Route(id == $order.routeId, roadType == RoadType.CITY)
    then
        modify($order) { setStatus(OrderStatus.UNFEASIBLE); }
        messages.add("Order " + $order.getId()
            + " UNFEASIBLE — ADR teret zabranjen u gradskoj zoni (ruta " + $route.getId()
            + " tip CITY). Izaberi regionalnu ili magistralnu trasu.");
end

// Ruta nema dovoljno kapaciteta za ovaj teret (npr. lokalni put sa ograničenjem mase)
rule "Validation_RouteCapacityExceeded"
    salience 875
    when
        $order : DeliveryOrder(status == OrderStatus.VALID, $weight : weightKg)
        $route : Route(id == $order.routeId, maxCapacityKg < $weight)
    then
        modify($order) { setStatus(OrderStatus.UNFEASIBLE); }
        messages.add("Order " + $order.getId() + " UNFEASIBLE — ruta " + $route.getId()
            + " dozvoljava max " + $route.getMaxCapacityKg() + " kg, a teret je "
            + $weight + " kg. Izaberi drugu trasu.");
end

// Procenjeno vreme rute premašuje rok dostave
rule "Validation_DeadlineMiss"
    salience 872
    when
        $order : DeliveryOrder(status == OrderStatus.VALID, $deadline : deliveryDeadlineMin, deliveryDeadlineMin > 0)
        $route : Route(id == $order.routeId, estimatedTimeHours * 60.0 > $deadline)
    then
        modify($order) { setStatus(OrderStatus.WAITING_RESOURCES); }
        messages.add("Order " + $order.getId() + " WAITING — ruta " + $route.getId()
            + " traje ~" + (int)($route.getEstimatedTimeHours() * 60) + " min"
            + ", rok dostave je samo " + $deadline + " min. Izaberi bržu trasu ili produži rok.");
end

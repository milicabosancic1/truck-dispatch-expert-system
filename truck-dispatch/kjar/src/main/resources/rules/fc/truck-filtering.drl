package rules;

import com.truckdispatch.truck_dispatch.model.DeliveryOrder;
import com.truckdispatch.truck_dispatch.model.Truck;
import com.truckdispatch.truck_dispatch.model.Route;
import com.truckdispatch.truck_dispatch.model.DispatchContext;
import com.truckdispatch.truck_dispatch.model.CandidateTruck;
import com.truckdispatch.truck_dispatch.model.OrderStatus;
import com.truckdispatch.truck_dispatch.model.TruckStatus;
import com.truckdispatch.truck_dispatch.model.TruckType;
import com.truckdispatch.truck_dispatch.model.OperationalContext;
import com.truckdispatch.truck_dispatch.model.CargoType;
import com.truckdispatch.truck_dispatch.model.RoadType;

global java.util.List messages;

// NIVO 2: Filtriranje kamiona

rule "CreateCandidateTruck_Normal"
    salience 800
    when
        $order : DeliveryOrder(status == OrderStatus.VALID)
        $route : Route(id == $order.routeId)
        not DispatchContext(context == OperationalContext.WINTER_CONDITIONS)
        $truck : Truck(
            status == TruckStatus.AVAILABLE,
            maxCapacityKg >= $order.weightKg,
            type.isAllowedOnRoadType($route.roadType) == true
        )
    then
        insert(new CandidateTruck($order, $truck));
end

rule "CreateCandidateTruck_Winter"
    salience 800
    when
        $order : DeliveryOrder(status == OrderStatus.VALID)
        $route : Route(id == $order.routeId)
        $ctx : DispatchContext(context == OperationalContext.WINTER_CONDITIONS, $factor : capacityFactor)
        $truck : Truck(
            status == TruckStatus.AVAILABLE,
            maxCapacityKg * $factor >= $order.weightKg,
            type.isAllowedOnRoadType($route.roadType) == true
        )
    then
        insert(new CandidateTruck($order, $truck));
end

rule "ExcludeLargeTruck_MorningPeak_City"
    salience 790
    when
        DispatchContext(context == OperationalContext.MORNING_PEAK)
        $route : Route(roadType == RoadType.CITY)
        $candidate : CandidateTruck(truck.type == TruckType.LARGE, order.routeId == $route.id)
    then
        retract($candidate);
        messages.add("Truck " + $candidate.getTruck().getId() + " excluded - LARGE truck banned in city zones during morning peak");
end

rule "ExcludeNoFrigoForRefrigerated"
    salience 790
    when
        $candidate : CandidateTruck(
            order.cargoType == CargoType.REFRIGERATED,
            truck.hasRefrigerationUnit == false
        )
    then
        retract($candidate);
end

rule "ExcludeNoAdrEquipmentForDangerous"
    salience 790
    when
        $candidate : CandidateTruck(
            order.cargoType == CargoType.HAZARDOUS,
            truck.hasAdrEquipment == false
        )
    then
        retract($candidate);
        messages.add("Truck " + $candidate.getTruck().getId() + " excluded - no ADR equipment");
end

// Iskljuci kamion ako procenjeni domet (fuelPercent * 10 km) nije dovoljan za rutu
// Pretpostavka: pun rezervoar = 1000 km; na X% goriva domet je X*10 km
rule "ExcludeTruck_InsufficientFuelForRoute"
    salience 790
    when
        $candidate : CandidateTruck($truck : truck, $order : order)
        Route(id == $order.routeId, $dist : distanceKm)
        Truck(this == $truck, $fuel : fuelPercent, fuelPercent * 10 < $dist)
    then
        retract($candidate);
        messages.add("Truck " + $truck.getId() + " excluded — fuel " + $fuel
            + "% (range ~" + ((int)($fuel * 10)) + " km) insufficient for "
            + $dist + " km route");
end

// Iskljuci kamion sa prekasnim servisom rashladnog sistema za REFRIGERATED nalog
// Post-validacija samo upozorava nakon dodele; ovo pravilo sprečava pogrešnu dodelu
rule "ExcludeRefrigerationServiceOverdue"
    salience 790
    when
        $candidate : CandidateTruck(
            order.cargoType == CargoType.REFRIGERATED,
            truck.daysSinceRefrigerationService > 30
        )
    then
        retract($candidate);
        messages.add("Truck " + $candidate.getTruck().getId()
            + " excluded — refrigeration system not serviced in "
            + $candidate.getTruck().getDaysSinceRefrigerationService() + " days (max 30)");
end

// Iskljuci kamione ispod minimalnog tipa koji nalog zahteva
rule "ExcludeTruckBelowMinType"
    salience 790
    when
        $candidate : CandidateTruck($order : order, $truck : truck)
        DeliveryOrder(this == $order, minTruckType != null, $min : minTruckType)
        Truck(this == $truck, type.isAtLeast($min) == false)
    then
        retract($candidate);
        messages.add("Truck " + $truck.getId() + " excluded - below minTruckType " + $min);
end

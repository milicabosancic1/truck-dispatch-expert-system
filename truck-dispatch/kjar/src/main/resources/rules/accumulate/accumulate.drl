package rules;

import com.truckdispatch.truck_dispatch.model.DeliveryOrder;
import com.truckdispatch.truck_dispatch.model.Truck;
import com.truckdispatch.truck_dispatch.model.Driver;
import com.truckdispatch.truck_dispatch.model.Alarm;
import com.truckdispatch.truck_dispatch.model.AlarmType;
import com.truckdispatch.truck_dispatch.model.OrderStatus;
import com.truckdispatch.truck_dispatch.model.TruckStatus;
import java.util.List;

global java.util.List messages;

// ACCUMULATE PRAVILA

// COLLECT LIST: Svi vozaci koji su prekoracili dozvoljeno radno vreme (> 9h)
rule "Accumulate_OverloadedDriver"
    salience 30
    no-loop true
    when
        not Alarm(type == AlarmType.OVERLOADED_DRIVER, entityId == "FLEET")
        $overdueDrivers : List(size > 0) from accumulate(
            Driver(workingHoursToday > 9, $id : id),
            collectList($id)
        )
    then
        insert(new Alarm(AlarmType.OVERLOADED_DRIVER, "FLEET",
                $overdueDrivers.size() + " driver(s) exceeded 9h limit: " + $overdueDrivers, $overdueDrivers.size()));
        messages.add("ALERT: " + $overdueDrivers.size() + " driver(s) exceeded 9h limit: " + $overdueDrivers);
end

// SUM: Ukupna tezina aktivnih naloga po kamionu prelazi maxCapacityKg
rule "Accumulate_OverloadedTruck"
    salience 30
    no-loop true
    when
        $truck : Truck($truckId : id, $maxCap : maxCapacityKg)
        not Alarm(type == AlarmType.OVERLOADED_TRUCK, entityId == $truckId)
        $total : Number(doubleValue > $maxCap) from accumulate(
            DeliveryOrder(
                status == OrderStatus.ASSIGNED || status == OrderStatus.IN_PROGRESS,
                assignedTruckId == $truckId,
                $w : weightKg
            ),
            sum($w)
        )
    then
        insert(new Alarm(AlarmType.OVERLOADED_TRUCK, $truckId,
                "Truck " + $truckId + " overloaded: " + $total + "kg (max " + $maxCap + "kg)", 0));
        messages.add("ALERT: truck " + $truckId + " total assigned weight " + $total + "kg exceeds capacity " + $maxCap + "kg!");
end

// AVERAGE: Prosecno kasnjenje po ruti > 30min (grupisano po routeId)
rule "Accumulate_AvgDelayByRoute"
    salience 30
    no-loop true
    when
        DeliveryOrder(status == OrderStatus.IN_PROGRESS, delayMin > 0, $routeId : routeId)
        $avgDelay : Number(doubleValue > 30) from accumulate(
            DeliveryOrder(status == OrderStatus.IN_PROGRESS,
                          routeId == $routeId, $d : delayMin),
            average($d)
        )
        not Alarm(type == AlarmType.PROBLEMATIC_ROUTE, entityId == $routeId)
    then
        insert(new Alarm(AlarmType.PROBLEMATIC_ROUTE, $routeId,
                "Route " + $routeId + " avg delay " + $avgDelay + "min", 0));
        messages.add("ALERT: route " + $routeId + " average delay=" + $avgDelay + "min!");
end

// SUM/COUNT: Prosecni radni sati tima > 7.5h
rule "Accumulate_TeamHoursWarning"
    salience 30
    no-loop true
    when
        not Alarm(type == AlarmType.SHIFT_WARNING, entityId == "TEAM")
        $avgHours : Number(doubleValue > 7.5) from accumulate(
            Driver(available == true, $h : workingHoursToday),
            average($h)
        )
    then
        insert(new Alarm(AlarmType.SHIFT_WARNING, "TEAM",
                "Team avg working hours: " + $avgHours, 0));
        messages.add("WARNING: team average working hours=" + $avgHours + "h -- consider shift change!");
end

// COUNT: Previše naloga ceka na raspored (> 5) — sistemski kapacitetni problem
rule "Accumulate_OrderBacklog"
    salience 30
    no-loop true
    when
        not Alarm(type == AlarmType.ORDER_BACKLOG, entityId == "FLEET")
        $count : Number(intValue > 5) from accumulate(
            DeliveryOrder(status == OrderStatus.WAITING_RESOURCES),
            count(1)
        )
    then
        insert(new Alarm(AlarmType.ORDER_BACKLOG, "FLEET",
                $count + " orders waiting for resources — fleet capacity insufficient", $count.intValue()));
        messages.add("ALERT: order backlog — " + $count + " orders in WAITING_RESOURCES, consider additional capacity!");
end

// COUNT: Kriticno malo slobodnih kamiona (< 2) dok postoje nalozi na cekanju
rule "Accumulate_FleetShortage"
    salience 30
    no-loop true
    when
        not Alarm(type == AlarmType.FLEET_SHORTAGE, entityId == "FLEET")
        exists DeliveryOrder(status == OrderStatus.WAITING_RESOURCES)
        $available : Number(intValue < 2) from accumulate(
            Truck(status == TruckStatus.AVAILABLE),
            count(1)
        )
    then
        insert(new Alarm(AlarmType.FLEET_SHORTAGE, "FLEET",
                "Fleet shortage: only " + $available + " truck(s) available with orders waiting", 0));
        messages.add("ALERT: fleet shortage — " + $available + " available truck(s) while orders are WAITING_RESOURCES!");
end

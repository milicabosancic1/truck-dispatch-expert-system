package rules;

import com.truckdispatch.truck_dispatch.model.DeliveryOrder;
import com.truckdispatch.truck_dispatch.model.RejectionReason;
import com.truckdispatch.truck_dispatch.model.OrderGroupMembership;
import com.truckdispatch.truck_dispatch.model.OrderStatus;

global java.util.List messages;

// BACKWARD CHAINING - Query 1: isCauseOfRejection
// Diagnoses why an order was not assigned -- recursively traces the cause chain

query "isCauseOfRejection" (String cause, String effect)
    RejectionReason( cause == cause, effect == effect )
    or
    ( RejectionReason( cause == cause, $intermediate : effect ) and
      isCauseOfRejection( $intermediate, effect; ) )
end

// Rule: diagnose winter capacity reduction as root cause
rule "BC_Diagnosis_Winter"
    salience 20
    when
        $order : DeliveryOrder(status == OrderStatus.WAITING_RESOURCES || status == OrderStatus.UNFEASIBLE)
        isCauseOfRejection( "WinterReducesCapacity", "OrderUnassigned"; )
    then
        messages.add("Order " + $order.getId() + " DIAGNOSIS: winter conditions reduced effective capacity - no truck available!");
end

// Rule: report all root causes of rejection (unbound cause)
rule "BC_Diagnosis_AllCauses"
    salience 20
    when
        $order : DeliveryOrder(status == OrderStatus.WAITING_RESOURCES || status == OrderStatus.UNFEASIBLE)
        isCauseOfRejection( $cause, "OrderUnassigned"; )
    then
        messages.add("Order " + $order.getId() + " DIAGNOSIS cause: " + $cause);
end

// BACKWARD CHAINING - Query 2: belongsToOrderCategory
// Order type hierarchy -- recursive classification

query "belongsToOrderCategory" (String item, String category)
    OrderGroupMembership( item == item, group == category )
    or
    ( OrderGroupMembership( item == item, $midCategory : group ) and
      belongsToOrderCategory( $midCategory, category; ) )
end

// Rule: special order detected -- verify truck equipment
rule "BC_SpecialOrderCheck"
    salience 20
    when
        $order : DeliveryOrder(status == OrderStatus.ASSIGNED, $type : cargoType.name())
        belongsToOrderCategory( $type, "SpecialOrder"; )
    then
        messages.add("Order " + $order.getId() + " is SPECIAL (" + $type + ") - verify truck equipment!");
end
